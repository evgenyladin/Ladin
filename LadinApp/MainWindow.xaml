<Window x:Class="LadinApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LadinApp"
        Title="Управление задачами" Height="780" Width="1300"
        Loaded="Window_Loaded" Closing="Window_Closing"
        Background="#FFE8F5E9" FontFamily="Segoe UI" FontSize="14">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:IsOverdueConverter x:Key="IsOverdueConverter"/>
        <DropShadowEffect x:Key="ShadowEffect" ShadowDepth="2" BlurRadius="8" Color="#20000000"/>

        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="#FF4A90E2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3A7BC8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF2D62A0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FFA0C4E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#FF6C757D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF5A6268"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF495057"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D9E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D9E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="4"
                                            Margin="2">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFEEF2F7"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#FFD4E6FC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,8"
                    Effect="{StaticResource ShadowEffect}">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="SearchBox" Width="200" VerticalContentAlignment="Center"/>
                    <Button Content="Поиск" Click="Search_Click" Margin="5,0,0,0" Width="70"
                            Style="{StaticResource ModernButton}"/>
                    <ComboBox x:Name="StatusFilter" Width="130" Margin="10,0,0,0"
                              SelectionChanged="StatusFilter_SelectionChanged">
                        <ComboBoxItem Content="Все"/>
                        <ComboBoxItem Content="Новая"/>
                        <ComboBoxItem Content="В процессе"/>
                        <ComboBoxItem Content="Завершена"/>
                    </ComboBox>
                    <ComboBox x:Name="CategoryFilter" Width="110" Margin="5,0,0,0"
                              SelectionChanged="CategoryFilter_SelectionChanged">
                        <ComboBoxItem Content="Все кат."/>
                        <ComboBoxItem Content="Work"/>
                        <ComboBoxItem Content="Study"/>
                        <ComboBoxItem Content="Personal"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>
                    <Button Content="Сброс" Click="ResetFilter_Click" Margin="5,0,0,0" Width="80"
                            Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,8"
                    Effect="{StaticResource ShadowEffect}">
                <StackPanel Orientation="Horizontal">
                    <Button Content="По приоритету" Click="SortPriority_Click" Width="120"
                            Style="{StaticResource ModernButton}"/>
                    <Button Content="По сроку" Click="SortDeadline_Click" Margin="5,0,0,0" Width="110"
                            Style="{StaticResource ModernButton}"/>
                    <Button Content="Важная/неважная" Click="ToggleImportant_Click" Margin="5,0,0,0" Width="130"
                            Style="{StaticResource ModernButton}"/>
                    <Button Content="Статистика" Click="Stats_Click" Margin="5,0,0,0" Width="100"
                            Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Border>

            <ListBox x:Name="TasksList" Grid.Row="2" SelectionChanged="TasksList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="RowBorder" Background="Transparent" CornerRadius="4">
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Text="★" Foreground="Gold"
                                           Visibility="{Binding IsImportant, Converter={StaticResource BoolToVisibility}}"
                                           FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Margin="5,0"
                                           Foreground="#FF2C3E50" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text=" [" Foreground="#FF7F8C8D" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Status}" Foreground="#FF3498DB" VerticalAlignment="Center"/>
                                <TextBlock Text="] " Foreground="#FF7F8C8D" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Deadline, StringFormat=dd.MM.yyyy}"
                                           Foreground="#FFE67E22" VerticalAlignment="Center"/>
                                <TextBlock Text=" (приор: " Foreground="#FF7F8C8D" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Priority}" Foreground="#FFE74C3C" VerticalAlignment="Center"/>
                                <TextBlock Text=") кат: " Foreground="#FF7F8C8D" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Category}" Foreground="#FF2C3E50" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource IsOverdueConverter}">
                                        <Binding Path="Status"/>
                                        <Binding Path="Deadline"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter TargetName="RowBorder" Property="Background" Value="#FFDDDD"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20"
                Effect="{StaticResource ShadowEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Название" Grid.Row="0" FontWeight="SemiBold" Foreground="#FF2C3E50"
                           FontSize="16" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleBox" Grid.Row="1" Margin="0,0,0,10"/>

                <TextBlock Text="Описание" Grid.Row="2" FontWeight="SemiBold" Foreground="#FF2C3E50"
                           FontSize="16" Margin="0,0,0,4"/>
                <TextBox x:Name="DescBox" Grid.Row="3" Height="70" TextWrapping="Wrap"
                         Margin="0,0,0,10" AcceptsReturn="True"/>

                <Grid Grid.Row="4" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Приоритет" FontWeight="SemiBold" Foreground="#FF2C3E50"
                                   FontSize="16" Margin="0,0,0,4"/>
                        <ComboBox x:Name="PriorityBox">
                            <ComboBoxItem Content="Низкий"/>
                            <ComboBoxItem Content="Средний"/>
                            <ComboBoxItem Content="Высокий"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Статус" FontWeight="SemiBold" Foreground="#FF2C3E50"
                                   FontSize="16" Margin="0,0,0,4"/>
                        <ComboBox x:Name="StatusBox">
                            <ComboBoxItem Content="Новый"/>
                            <ComboBoxItem Content="В процессе"/>
                            <ComboBoxItem Content="Завершенный"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="5" Margin="0,0,0,10">
                    <TextBlock Text="Категория" FontWeight="SemiBold" Foreground="#FF2C3E50"
                               FontSize="16" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CategoryBox">
                        <ComboBoxItem Content="Работа"/>
                        <ComboBoxItem Content="Учёба"/>
                        <ComboBoxItem Content="Личное"/>
                        <ComboBoxItem Content="Другое"/>
                    </ComboBox>
                </StackPanel>

                <TextBlock Text="Срок выполнения" Grid.Row="6" FontWeight="SemiBold" Foreground="#FF2C3E50"
                           FontSize="16" Margin="0,0,0,4"/>
                <DatePicker x:Name="DeadlinePicker" Grid.Row="7" Margin="0,0,0,15"
                            VerticalAlignment="Center"/>

                <WrapPanel Grid.Row="8" HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,190,0,0" Orientation="Horizontal"
                       ItemWidth="115" ItemHeight="40" Height="128" Width="428">
                    <Button Content="Добавить" Click="Add_Click" Width="105"
                        Style="{StaticResource ModernButton}" Margin="5"/>
                    <Button Content="Обновить" Click="Update_Click" Width="105"
                        Style="{StaticResource ModernButton}" Margin="5"/>
                    <Button Content="Удалить" Click="Delete_Click" Width="105"
                        Style="{StaticResource SecondaryButton}" Margin="5"/>
                    <Button Content="Сохранить" Click="Save_Click" Width="105"
                        Style="{StaticResource ModernButton}" Margin="5"/>
                    <Button Content="Загрузить" Click="Load_Click" Width="105"
                        Style="{StaticResource SecondaryButton}" Margin="5"/>
                    <Button Content="Архивировать" Click="Archive_Click"
                        Style="{StaticResource SecondaryButton}" Margin="5,5,-13,5"/>
                    <Button Content="Просмотр архива" Click="ShowArchive_Click"
                        Style="{StaticResource SecondaryButton}" Margin="8,5,-43,5"/>
                    <Button Content="Экспорт CSV" Click="ExportCsv_Click"
                        Style="{StaticResource SecondaryButton}" Margin="48,5,-75,5"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>