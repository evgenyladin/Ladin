<Window x:Class="LadinApp.ArchiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Архив задач" Height="400" Width="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ListBox x:Name="ArchiveList" Grid.Row="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" Margin="5,0"/>
                        <TextBlock Text=" ["/>
                        <TextBlock Text="{Binding Deadline, StringFormat=dd.MM.yyyy}"/>
                        <TextBlock Text="] "/>
                        <TextBlock Text="{Binding Category}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Content="Удалить из архива" Click="Delete_Click" Width="140" Margin="5,0"/>
            <Button Content="Закрыть" Click="Close_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>